# FlowModus Sidecar Configuration
# Copy this file to .env.flowmodus and fill in your values.

# Proxy server settings
FLOWMODUS_PROXY_HOST=127.0.0.1
FLOWMODUS_PROXY_PORT=8080

# Graceful shutdown timeout in seconds
FLOWMODUS_SHUTDOWN_TIMEOUT=30

# Maximum number of retries for invisible retry
FLOWMODUS_MAX_RETRY_COUNT=3

# Data sharing: "on" or "off" (default off)
FLOWMODUS_DATA_SHARING=off

# Local registry path (for testing; future versions use IPFS)
FLOWMODUS_LOCAL_REGISTRY=~/.flowmodus/local_registry.json
